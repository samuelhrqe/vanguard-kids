<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet_safety"
    android:orientation="vertical"
    android:padding="16dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#5A5F73"
        android:backgroundTint="#5A5F73" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Encerrar rota?"
        android:textColor="#FF4D4D"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:text="Verifique se todos os alunos desembarcaram antes de encerrar. O sistema detectou sensores ativos:"
        android:textColor="#A0A3B1"
        android:textSize="14sp" />

    <LinearLayout
        android:id="@+id/dynamicSeatsContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />

    <Button
        android:id="@+id/btnDismissBottomSheet"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="16dp"
        android:backgroundTint="#2C3440"
        android:text="ENTENDIDO"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        app:cornerRadius="8dp" />

</LinearLayout>