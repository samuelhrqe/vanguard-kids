<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:id="@+id/seatsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/tvMqttStatus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cardSeat01"
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_seat_card_unknown"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/ivSeat01"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:contentDescription="Assento 01"
                    android:scaleType="centerInside"
                    android:src="@drawable/banco_verde" />

                <TextView
                    android:id="@+id/tvSeat01"
                    android:textColor="@android:color/white"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="01&#10;Sem dados"
                    android:textAlignment="center"
                    android:textSize="13sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardSeat02"
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:background="@drawable/bg_seat_card_unknown"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/ivSeat02"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:contentDescription="Assento 02"
                    android:scaleType="centerInside"
                    android:src="@drawable/banco_verde" />

                <TextView
                    android:textColor="@android:color/white"
                    android:id="@+id/tvSeat02"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="02&#10;Sem dados"
                    android:textAlignment="center"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <LinearLayout
                android:id="@+id/cardSeat03"
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_seat_card_unknown"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/ivSeat03"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:contentDescription="Assento 03"
                    android:scaleType="centerInside"
                    android:src="@drawable/banco_verde" />

                <TextView
                    android:id="@+id/tvSeat03"
                    android:textColor="@android:color/white"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="03&#10;Sem dados"
                    android:textAlignment="center"
                    android:textSize="13sp" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/cardSeat04"
                android:layout_width="132dp"
                android:layout_height="132dp"
                android:background="@drawable/bg_seat_card_unknown"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/ivSeat04"
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    android:contentDescription="Assento 04"
                    android:scaleType="centerInside"
                    android:src="@drawable/banco_verde" />

                <TextView
                    android:id="@+id/tvSeat04"
                    android:textColor="@android:color/white"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:maxLines="2"
                    android:text="04&#10;Sem dados"
                    android:textAlignment="center"
                    android:textSize="13sp" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/tvMqttStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="Conectando..."
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>