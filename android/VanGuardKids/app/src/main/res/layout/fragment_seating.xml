<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="0dp">

    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"

        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="0dp"
        android:layout_marginBottom="8dp"

        android:background="@drawable/bg_panel_layer"
        android:paddingTop="32dp"
        android:paddingBottom="24dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/seatsContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:gravity="center"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/cardSeat01"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_seat_card_free"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/ivSeat01"
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        android:contentDescription="Assento 01"
                        android:scaleType="fitCenter"
                        android:src="@drawable/outline_airline_seat_recline_extra_24"
                        app:tint="#2CE416" />

                    <TextView
                        android:id="@+id/tvSeat01"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:text="01\nLivre"
                        android:textAlignment="center"
                        android:textColor="@android:color/white"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardSeat02"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@drawable/bg_seat_card_free"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/ivSeat02"
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        android:contentDescription="Assento 02"
                        android:scaleType="fitCenter"
                        android:src="@drawable/outline_airline_seat_recline_extra_24"
                        app:tint="#2CE416" />

                    <TextView
                        android:id="@+id/tvSeat02"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:text="02\nLivre"
                        android:textAlignment="center"
                        android:textColor="@android:color/white"
                        android:textSize="15sp" />
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/cardSeat03"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:layout_marginEnd="10dp"
                    android:background="@drawable/bg_seat_card_free"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/ivSeat03"
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        android:contentDescription="Assento 03"
                        android:scaleType="fitCenter"
                        android:src="@drawable/outline_airline_seat_recline_extra_24"
                        app:tint="#2CE416" />

                    <TextView
                        android:id="@+id/tvSeat03"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:text="03\nLivre"
                        android:textAlignment="center"
                        android:textColor="@android:color/white"
                        android:textSize="15sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/cardSeat04"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:background="@drawable/bg_seat_card_free"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="8dp">

                    <ImageView
                        android:id="@+id/ivSeat04"
                        android:layout_width="82dp"
                        android:layout_height="82dp"
                        android:contentDescription="Assento 04"
                        android:scaleType="fitCenter"
                        android:src="@drawable/outline_airline_seat_recline_extra_24"
                        app:tint="#2CE416" />

                    <TextView
                        android:id="@+id/tvSeat04"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:maxLines="2"
                        android:text="04\nLivre"
                        android:textAlignment="center"
                        android:textColor="@android:color/white"
                        android:textSize="15sp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/routeActionsContainer"
            android:layout_width="match_parent"
            android:layout_height="128dp"
            android:layout_marginTop="26dp">

            <Button
                android:id="@+id/btnEndRoute"
                android:layout_width="188dp"
                android:layout_height="52dp"
                android:layout_marginTop="2dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:backgroundTint="#FF4B4B"
                android:gravity="center"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="ENCERRAR ROTA"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_flag"
                app:iconTint="@android:color/white"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <Button
                android:id="@+id/btnManageRoute"
                android:layout_width="188dp"
                android:layout_height="52dp"
                android:layout_marginBottom="2dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:backgroundTint="#2C3440"
                android:gravity="center"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:text="GERENCIAR ROTA"
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:textStyle="bold"
                app:icon="@drawable/ic_route"
                app:iconTint="@android:color/white"
                app:iconGravity="textStart"
                app:iconPadding="8dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <LinearLayout
                android:id="@+id/routeInfoContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="4dp"
                android:gravity="center"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/btnEndRoute"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_bias="0.68">

                <TextView
                    android:id="@+id/tvRouteName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="ROTA 01"
                    android:textColor="@android:color/white"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvRouteStart"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="14:15"
                        android:textColor="#C3CAD4"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="7dp"
                        android:layout_marginEnd="7dp"
                        android:text="•"
                        android:textColor="#C3CAD4"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tvRouteStops"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:maxLines="1"
                        android:text="8 paradas"
                        android:textColor="#C3CAD4"
                        android:textSize="13sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvRouteSafety"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="7dp"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="Verificando assentos"
                    android:textColor="#C3CAD4"
                    android:textSize="12sp" />
            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
        <Space
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
        <TextView
            android:id="@+id/tvMqttStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="Broker MQTT"
            android:textColor="#C3CAD4"
            android:textSize="13sp"
            android:drawablePadding="8dp"
            app:drawableStartCompat="@drawable/shape_circle_status" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>