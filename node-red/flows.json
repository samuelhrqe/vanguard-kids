    {
        "id": "ed62f5b56222206f",
        "type": "function",
        "z": "e36b668a12db8bb5",
        "name": "Format Seats Table",
        "func": "msg.payload = msg.payload.seats.map(seat => ({\n    seat: seat.seat,\n    status: seat.occupied ? \"Occupied\" : \"Available\",\n    occupied: seat.occupied,\n    weight_g: Math.round(seat.weight_g),\n    voltage: Number(seat.voltage.toFixed(2)),\n    adc_raw: seat.adc_raw,\n    last_update: seat.datetime_brt\n}));\n\nreturn msg;",
