    },
    {
        "id": "5ee367f76d046d14",
        "type": "function",
        "z": "e36b668a12db8bb5",
        "name": "Update Current Seats",
        "func": "const data = msg.payload;\n\nlet seats = flow.get(\"currentSeats\") || {\n    \"seat-01\": null,\n    \"seat-02\": null,\n    \"seat-03\": null,\n    \"seat-04\": null\n};\n\nseats[data.seat] = {\n    client_id: data.client_id,\n    seat: data.seat,\n    adc_raw: data.adc_raw,\n    voltage: data.voltage,\n    weight_g: data.weight_g,\n    occupied: data.occupied,\n    ts: data.ts,\n    ts_ms: data.ts_ms,\n    datetime_brt: data.datetime_brt\n};\n\nflow.set(\"currentSeats\", seats);\n\nconst seatList = Object.values(seats)\n    .filter(seat => seat !== null);\n\nconst occupiedCount = seatList\n    .filter(seat => seat.occupied)\n    .length;\n\nmsg.payload = {\n    seats: seatList,\n    occupied_count: occupiedCount,\n    available_count: 4 - occupiedCount,\n    total_seats: 4\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
